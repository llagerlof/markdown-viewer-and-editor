{
  "name": "markdown-viewer-and-editor",
  "version": "1.1.3",
  "private": true,
  "type": "module",
  "description": "Two-pane Markdown viewer and editor: source on the left with syntax highlighting, Milkdown live editor on the right. Built with Svelte and Vite.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@milkdown/crepe": "^7.21.1",
    "@milkdown/kit": "^7.21.1",
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.38.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "svelte": "^5.55.8",
    "vite": "^8.0.13",
    "wrangler": "^4.94.0"
  }
}
